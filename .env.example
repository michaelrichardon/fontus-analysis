# Jira-Verbindung – Werte ausfüllen, Datei NICHT ins Git committen!
JIRA_BASE_URL=https://jira.dein-unternehmen.de
JIRA_PAT=DEIN_PERSONAL_ACCESS_TOKEN_HIER
JIRA_PROJECT=FONTUS

# SSL-Zertifikat
# false                   = Prüfung deaktivieren (self-signed)
# true                    = Prüfung aktivieren
# /pfad/zum/ca-bundle.crt = eigenes CA-Zertifikat
JIRA_SSL_VERIFY=false

# Feature-Team-Feld (wird beim ersten Start automatisch ermittelt)
# Danach hier eintragen um die Erkennung beim nächsten Start zu überspringen:
# JIRA_FEATURE_TEAM_FIELD=customfield_11101

# Die Feature Teams und das Mapping sind direkt im Skript definiert (FEATURE_TEAMS / TEAM_MAPPING)
